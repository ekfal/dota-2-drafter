{
  "name": "dota-draft-helper-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ingest worker: poll OpenDota /proMatches -> Supabase (matches + picks_bans).",
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:local": "tsx --env-file=.env.local src/ingest.ts",
    "aggregate": "tsx src/aggregate.ts",
    "aggregate:local": "tsx --env-file=.env.local src/aggregate.ts",
    "backfill": "tsx src/backfill.ts",
    "backfill:local": "tsx --env-file=.env.local src/backfill.ts",
    "sync-teams": "tsx src/sync-teams.ts",
    "sync-teams:local": "tsx --env-file=.env.local src/sync-teams.ts",
    "patches": "tsx src/patches.ts",
    "patches:local": "tsx --env-file=.env.local src/patches.ts",
    "stratz": "tsx src/stratz.ts",
    "stratz:local": "tsx --env-file=.env.local src/stratz.ts",
    "roster": "tsx src/roster.ts",
    "roster:local": "tsx --env-file=.env.local src/roster.ts",
    "detect-merge:local": "tsx --env-file=.env.local src/detect-merge.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
