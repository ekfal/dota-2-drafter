# Salin ke .env.local (jangan commit). GitHub Actions: pakai Secrets.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY      # service_role: bypass RLS untuk tulis
OPENDOTA_API_KEY=                                # opsional; kosong = 60 req/min limit
INGEST_MAX_MATCHES=25                            # batas match baru per run (incremental, cicil backfill)
